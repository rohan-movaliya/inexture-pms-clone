{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client", "vite-plugin-svgr/client"],

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "allowJs": true,
    "alwaysStrict": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "pretty": true,

    /* Misc */
    "composite": true,
    "allowSyntheticDefaultImports": true,

    /* Extra */
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"],
      "@components/*": ["components/*"],
      "@assets/*": ["assets/*"],
      "@utils/*": ["utils/*"],
      "@services/*": ["services/*"],
      "@pages/*": ["pages/*"],
      "@store/*": ["store/*"]
    }
  },
  "include": [
    "src",
    "tests",
    "src/types/index.d.ts",
    "vite.config.ts",
    "vitest.setup.mts",
    "postcss.config.js",
    ".prettierrc",
    ".svgrrc.js"
  ]
}
